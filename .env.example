# 影片字幕自動翻譯系統 - 環境變數範例

# 伺服器配置
HOST=0.0.0.0
PORT=8000

# Whisper 模型配置
WHISPER_MODEL_SIZE=base  # tiny, base, small, medium, large

# 並發控制
MAX_CONCURRENT_JOBS=2

# 儲存配置
STORAGE_BASE_DIR=storage
CLEANUP_HOURS=24

# 日誌配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# 檔案限制
MAX_FILE_SIZE_GB=5
MAX_VIDEO_DURATION_HOURS=2
MIN_DISK_SPACE_GB=1
