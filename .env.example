# 影片字幕自動翻譯系統 - 環境變數範例

# 伺服器配置
HOST=0.0.0.0
PORT=8000

# Whisper 模型配置
# 可用模型：tiny, base, small, medium, large-v1, large-v2, large-v3
# 也可填 large（等同 large-v3）
# CPU 建議：base / small / medium
# GPU 建議：large-v2（WhisperX 推薦）/ large-v3
# ⚠️ large 系列在 CPU 上會非常慢
WHISPER_MODEL_SIZE=base

# 並發控制
MAX_CONCURRENT_JOBS=2

# 儲存配置
# 所有上傳檔案和字幕輸出都存放於此路徑（每個 job 一個資料夾）
# 預設為專案目錄下的 storage/，可改為絕對路徑
BASE_STORAGE_PATH=./storage
CLEANUP_HOURS=24

# 日誌配置
LOG_LEVEL=INFO
LOG_FILE=logs/app.log

# Hugging Face 配置（可選）
# 設置為空字符串以隱藏警告訊息
# 注意：這些設置不影響功能，只是隱藏下載模型時的警告
HF_HUB_DISABLE_TELEMETRY=1
TRANSFORMERS_VERBOSITY=error

# 檔案限制
MAX_FILE_SIZE_GB=5
MAX_VIDEO_DURATION_HOURS=2
MIN_DISK_SPACE_GB=1
